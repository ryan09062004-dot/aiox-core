{
  "expo": {
    "name": "ShapeAI",
    "slug": "shapeai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "shapeai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shapeai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O ShapeAI usa a câmera para capturar fotos de análise corporal.",
        "NSPhotoLibraryUsageDescription": "O ShapeAI acessa sua biblioteca de fotos para análise corporal.",
        "NSPhotoLibraryAddUsageDescription": "O ShapeAI salva imagens na sua galeria."
      }
    },
    "android": {
      "package": "com.shapeai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-media-library",
      [
        "expo-camera",
        {
          "cameraPermission": "O ShapeAI usa a câmera para capturar fotos de análise corporal."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4CAF50",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2a837be-0915-4116-86d7-b438cab06296"
      }
    },
    "owner": "ryan13848",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d2a837be-0915-4116-86d7-b438cab06296"
    }
  }
}
